    "@lucide/vue": "^1.17.0",
    "pinia": "^3.0.4",
    "roboto-fontface": "^0.10.0",
    "vue": "^3.5.35",
    "vuetify": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.3"
  }
}
